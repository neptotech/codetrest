{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codetrest",
  "version": "2.1.4",
  "identifier": "com.redoc.codetrest",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Codetrest — Your Ultimate Markdown-Powered Notes Hub",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "publisher": "redoc"
  }
}
